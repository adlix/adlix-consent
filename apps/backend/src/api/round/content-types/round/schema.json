{
  "collectionName": "rounds",
  "info": {
    "singularName": "round",
    "pluralName": "rounds",
    "displayName": "Round",
    "description": "Abstimmungsrunde innerhalb eines Projekts"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "roundNumber": {
      "type": "integer",
      "required": true,
      "min": 1
    },
    "proposal": {
      "type": "text",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["information", "reaction", "adjustment", "voting", "integration", "completed"],
      "default": "information"
    },
    "startDate": {
      "type": "datetime"
    },
    "endDate": {
      "type": "datetime"
    },
    "phaseStartedAt": {
      "type": "datetime"
    },
    "phaseDeadline": {
      "type": "datetime"
    },
    "reminderSent": {
      "type": "boolean",
      "default": false
    },
    "votes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::vote.vote",
      "mappedBy": "round"
    },
    "objections": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::objection.objection",
      "mappedBy": "round"
    },
    "comments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::comment.comment",
      "mappedBy": "round"
    },
    "project": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::project.project",
      "inversedBy": "rounds",
      "required": true
    }
  }
}
