{
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project",
    "description": "Consent-Projekt mit Beschreibung und Teilnehmern"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "maxLength": 200
    },
    "description": {
      "type": "text",
      "required": true
    },
    "goal": {
      "type": "text"
    },
    "tension": {
      "type": "text"
    },
    "status": {
      "type": "enumeration",
      "enum": ["draft", "active", "completed", "beschlossen", "archived"],
      "default": "draft"
    },
    "outcome": {
      "type": "text"
    },
    "nextSteps": {
      "type": "text"
    },
    "evaluationDate": {
      "type": "datetime"
    },
    "minorObjectionsLog": {
      "type": "json"
    },
    "currentRound": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::round.round"
    },
    "rounds": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::round.round",
      "mappedBy": "project"
    },
    "participants": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "plugin::users-permissions.user"
    },
    "owner": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "circle": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::circle.circle",
      "inversedBy": "projects"
    }
  }
}
