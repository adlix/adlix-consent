{
  "collectionName": "votes",
  "info": {
    "singularName": "vote",
    "pluralName": "votes",
    "displayName": "Vote",
    "description": "Consent-Abstimmungsstimme in einer Runde"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "choice": {
      "type": "enumeration",
      "enum": ["consent", "minor_objection", "major_objection", "abstain"],
      "required": true
    },
    "reason": {
      "type": "text"
    },
    "previousChoice": {
      "type": "enumeration",
      "enum": ["consent", "minor_objection", "major_objection", "abstain"]
    },
    "reasonForChange": {
      "type": "text"
    },
    "voteHistory": {
      "type": "json"
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "round": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::round.round",
      "required": true
    },
    "abstention": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::abstention.abstention",
      "mappedBy": "vote"
    }
  }
}
