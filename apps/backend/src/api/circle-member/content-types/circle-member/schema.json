{
  "kind": "collectionType",
  "collectionName": "circle_members",
  "info": {
    "singularName": "circle-member",
    "pluralName": "circle-members",
    "displayName": "Circle Member",
    "description": "Mitgliedschaft eines Benutzers in einem Kreis"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "circle": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::circle.circle",
      "inversedBy": "circleMembers",
      "required": true
    },
    "user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "required": true
    },
    "role": {
      "type": "enumeration",
      "enum": ["member", "facilitator", "secretary"],
      "default": "member"
    }
  }
}
